# ============================================================
# Content Repurposing Agent — environment configuration
# Copy to `.env` and fill in. Required vars fail loudly at startup.
# ============================================================

# ---- LLM (Groq — free tier) --------------------------------
# Get a free key at https://console.groq.com/keys
LLM_PROVIDER=groq
LLM_API_KEY=gsk_your_groq_key_here
LLM_MODEL=llama-3.3-70b-versatile

# ---- Langfuse (observability) — OPTIONAL -------------------
# Leave blank to disable tracing. Free cloud: https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ---- Pipeline tuning ---------------------------------------
MAX_CLIPS=6
MAX_CRITIC_ROUNDS=2

# ---- Storage -----------------------------------------------
DB_PATH=jobs.sqlite
OUTPUT_DIR=outputs
